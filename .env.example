PUBLIC_BFF_URL=https://<public-bff-host>

# Optional defaults for requests
PROJECT_ID=
HTTP_TIMEOUT_SEC=60

# Optional explicit authorization header (highest priority after --auth-header)
AUTH_HEADER=

# IAM flow (used when AUTH_HEADER is empty)
IAM_KEY_ID=
IAM_SECRET=
IAM_ENDPOINT=https://iam.api.cloud.ru

# Optional compatibility field from shared credentials profile
CUSTOMER_ID=
